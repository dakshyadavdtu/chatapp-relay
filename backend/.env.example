PORT=3000

# Comma-separated list of origins allowed to call the API with credentials.
# Leave empty to disable CORS for cross-origin calls.
ALLOWED_ORIGINS=

# Session cookie flags. Set COOKIE_SECURE=1 when serving over HTTPS.
# COOKIE_SAMESITE may be Lax, Strict, or None (None requires Secure).
COOKIE_SECURE=0
COOKIE_SAMESITE=Lax

# Seed a starter admin account on boot. Both must be set together.
# The admin can list users and soft-delete messages via /api/admin/*.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Session lifetime in milliseconds. Defaults to 24h (86400000).
# Sessions extend on successful /api/auth/refresh.
SESSION_TTL_MS=
