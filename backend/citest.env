# Non-production values for automated tests only (Mongo/Redis on localhost).
# Loaded via: DOTENV_CONFIG_PATH=./citest.env node -r dotenv/config ...
NODE_ENV=development
PORT=3999
ALLOW_LOCAL_DB=true
DB_URI=mongodb://127.0.0.1:27017/relay_ci
REDIS_URL=redis://127.0.0.1:6379
JWT_SECRET=test-jwt-secret-for-ci-only-32chars!!
REFRESH_PEPPER=test-refresh-pepper-ci-only-32chars!!
WS_PATH=/ws
CORS_ORIGIN=http://127.0.0.1:5173
ROOT_ADMIN_EMAIL=admin@example.com
ROOT_ADMIN_PASSWORD=adminpass123456
METRICS_MODE=open
