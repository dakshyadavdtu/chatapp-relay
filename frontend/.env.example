# Optional. Prefix for HTTP calls and asset URLs (e.g. /uploads/...).
# Leave empty in dev; Vite proxies /api and /uploads to the backend.
# Set to the backend origin for non-local or split-host builds.
VITE_API_BASE_URL=

# Optional. Full WebSocket URL without the /ws path (e.g. ws://localhost:3000).
# Leave empty to use the same origin as the page; in dev Vite proxies /ws to the backend.
# If you set this, /ws is appended automatically when it is missing.
VITE_WS_URL=
